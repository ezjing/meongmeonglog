{
  "expo": {
    "name": "멍멍로그",
    "slug": "meongmeonglog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "meongmeonglog",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ezjing.meongmeonglog",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "산책 경로와 거리를 기록하기 위해 위치 정보가 필요합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "산책 중 화면이 꺼져도 경로와 거리를 기록하기 위해 위치 정보가 필요합니다.",
        "NSPhotoLibraryUsageDescription": "강아지 프로필 사진과 산책 사진을 등록하기 위해 사진 접근이 필요합니다.",
        "NSCameraUsageDescription": "강아지 프로필 사진과 산책 사진을 촬영하기 위해 카메라 접근이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF9E1",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ezjing.meongmeonglog",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF9E1",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "산책 경로와 거리를 기록하기 위해 위치 정보가 필요합니다.",
          "locationAlwaysAndWhenInUsePermission": "산책 중 화면이 꺼져도 경로와 거리를 기록하기 위해 위치 정보가 필요합니다.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "강아지 프로필 사진과 산책 사진을 등록하기 위해 사진 접근이 필요합니다.",
          "cameraPermission": "강아지 프로필 사진과 산책 사진을 촬영하기 위해 카메라 접근이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
